PORT=3001
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
MONGODB_URI=mongodb://localhost:27017/uptime-monitor
JWT_SECRET=change-me
JWT_EXPIRE=7d
PASSWORD_RESET_CODE_EXPIRE_MINUTES=10
FRONTEND_URL=http://localhost:5173/
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASSWORD=your-sendgrid-api-key
EMAIL_FROM="Uptime Warden <your-verified-sender@example.com>"
ALLOW_DEV_PASSWORD_RESET_FALLBACK=false
INVITATION_ALLOW_WITHOUT_EMAIL=false
NODE_ENV=development
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false
GEMINI_API_KEY=your-gemini-api-key
# Optional aliases also supported by the backend:
# GOOGLE_API_KEY=your-gemini-api-key
# API_KEY=your-gemini-api-key
